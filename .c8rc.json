{
  "all": true,
  "src": ["src"],
  "include": ["src/**/*.js", "shared.js"],
  "exclude": [
    "node_modules/**",
    "tests/**",
    "coverage/**",
    "docs/**"
  ],
  "reporter": ["text", "lcov", "json-summary"],
  "report-dir": "coverage",
  "clean": true,
  "skip-full": false,
  "watermarks": {
    "lines": [60, 80],
    "functions": [50, 70],
    "branches": [70, 90],
    "statements": [60, 80]
  }
}
